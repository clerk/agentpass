{
  "compilerOptions": {
    "jsx": "react-jsx",
    "moduleResolution": "Bundler",
    "module": "ESNext",
    "target": "ES2022",
    "skipLibCheck": true,
    "strictNullChecks": true,
    "types": ["vite/client"],
    "baseUrl": ".",
    "paths": {
      "fumadocs-mdx:collections/*": [".source/*"]
    }
  },
  "include": ["src", "vite.config.ts", "source.config.ts"]
}
