{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Service Provider Init Redeem Request/Response",
  "type": "object",
  "properties": {
    "request": {
      "type": "object",
      "required": [
        "artifact"
      ],
      "properties": {
        "artifact": {
          "type": "object",
          "required": [
            "type",
            "value"
          ],
          "properties": {
            "type": {
              "type": "string",
              "const": "service_signin_bootstrap"
            },
            "value": {
              "type": "string",
              "minLength": 1
            }
          },
          "additionalProperties": true
        },
        "runtime_proof": {
          "type": "object"
        },
        "delegating_principal_domain": {
          "type": "string",
          "pattern": "^[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?(?:\\.[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?)+$",
          "description": "Delegating principal domain used by Service Providers for authoritative precedence enforcement (recommended if artifact is opaque)."
        }
      },
      "additionalProperties": true
    },
    "response": {
      "type": "object",
      "required": [
        "initialization_url"
      ],
      "properties": {
        "initialization_url": {
          "type": "string",
          "format": "uri",
          "pattern": "^https://"
        },
        "expires_at": {
          "type": "string",
          "format": "date-time"
        },
        "one_time": {
          "type": "boolean"
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
