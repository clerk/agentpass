{
  "name": "@agentpass/authority",
  "version": "0.1.0",
  "description": "AgentPass Authority SDK for Cloudflare Workers — implement a spec-compliant AgentPass Authority with minimal code",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js"
    },
    "./durable-objects": {
      "types": "./dist/durable-objects/durable-objects.d.ts",
      "import": "./dist/durable-objects/durable-objects.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250313.0",
    "react": "^19.0.0",
    "@types/react": "^19.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "files": [
    "dist"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/clerk/agentpass"
  }
}
