{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AgentPass Service Provider Metadata",
  "type": "object",
  "required": [
    "kind",
    "service",
    "trust",
    "endpoints"
  ],
  "properties": {
    "kind": {
      "type": "string",
      "const": "service"
    },
    "service": {
      "type": "object",
      "required": [
        "origin"
      ],
      "properties": {
        "origin": {
          "type": "string",
          "format": "uri",
          "pattern": "^https://"
        },
        "name": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true
    },
    "trust": {
      "type": "object",
      "properties": {
        "accepted_authorities": {
          "type": "array",
          "items": {
            "type": "string",
            "format": "uri",
            "pattern": "^https://"
          },
          "minItems": 1,
          "uniqueItems": true
        }
      },
      "additionalProperties": true
    },
    "endpoints": {
      "type": "object",
      "required": [
        "resolve_deployments",
        "init",
        "initialize"
      ],
      "properties": {
        "resolve_deployments": {
          "type": "string",
          "pattern": "^https://"
        },
        "init": {
          "type": "string",
          "pattern": "^https://"
        },
        "initialize": {
          "type": "string",
          "pattern": "^https://"
        }
      },
      "additionalProperties": true
    },
    "session": {
      "type": "object"
    }
  },
  "additionalProperties": true
}
