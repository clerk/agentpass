{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AgentPass Authority Metadata",
  "type": "object",
  "required": [
    "kind",
    "issuer",
    "endpoints"
  ],
  "properties": {
    "kind": {
      "type": "string",
      "const": "authority"
    },
    "issuer": {
      "type": "string",
      "format": "uri",
      "pattern": "^https://"
    },
    "endpoints": {
      "type": "object",
      "required": [
        "requests",
        "request_status"
      ],
      "properties": {
        "requests": {
          "type": "string",
          "pattern": "^https://"
        },
        "request_status": {
          "type": "string",
          "pattern": "^https://"
        },
        "events": {
          "type": "string",
          "pattern": "^https://"
        }
      },
      "additionalProperties": true
    },
    "crypto": {
      "type": "object",
      "required": [
        "jwks_uri"
      ],
      "properties": {
        "jwks_uri": {
          "type": "string",
          "format": "uri",
          "pattern": "^https://"
        },
        "alg": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "uniqueItems": true
        }
      },
      "additionalProperties": true
    },
    "approval": {
      "type": "object",
      "properties": {
        "modes": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "poll",
              "sse"
            ]
          },
          "uniqueItems": true
        },
        "default_ttl_seconds": {
          "type": "integer",
          "minimum": 1
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
